  "info": {
    "_postman_id": "4d409450-00e3-4da0-85ee-2b77a3b3f2c7",
    "name": "Mastercard Payment Gateway REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Mastercard Payment Gateway exposes a JSON REST API for processing\npayments, managing orders, and integrating hosted checkout, sessions,\ntokenization, 3-D Secure authentication, agreements, batches, and\nwallet operations. All transaction operations on an order use a single\nURL pattern parameterized by merchant, order, and transaction\nidentifiers; the specific operation (AUTHORIZE, PAY, CAPTURE, REFUND,\nVOID, VERIFY, etc.) is selected by the `apiOperation` body field.\n\n\nContact Support:\n Name: Mastercard Payment Gateway Services",
      "type": "text/plain"
    }
  }
